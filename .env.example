PUBLIC_BASE_URL=https://your-domain.example.com
PORT=3000

# Telegram-уведомления
TG_BOT_TOKEN=your_bot_token
TG_ADMIN_IDS=123456789,987654321
TG_IT_ADMIN_IDS=123456789

# CRM-бот: ID админов для inline-кнопок (по умолчанию = TG_ADMIN_IDS)
# CRM_BOT_ADMIN_IDS=123456789,987654321

# CRM-бот: пути к файлам (нужны только если crm-support-bot развёрнут рядом)
# По умолчанию — ../crm-support-bot/data/ (временное решение, будет убрано в Этапе 5)
# CRM_BOT_TICKETS_FILE=/absolute/path/to/crm-support-bot/data/tickets.json
# CRM_BOT_EXCEL_FILE=/absolute/path/to/crm-support-bot/data/crm_support_log.xlsx

# Админ пин-коды (через запятую)
ADMIN_PINS=1234

# SMTP (опционально)
# SMTP_USER=your@yandex.ru
# SMTP_PASS=app_password
